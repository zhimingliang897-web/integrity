{
  "search_roots": ["C:\\Users", "D:\\", "E:\\"],
  "excluded_dirs": [
    "Windows",
    "Program Files",
    "Program Files (x86)",
    "ProgramData",
    "AppData",
    "$Recycle.Bin",
    "node_modules",
    ".git",
    "__pycache__",
    ".vscode",
    ".idea",
    "venv",
    ".venv"
  ],
  "max_results": 20,
  
  "_comment_api": "API 配置 - 填写你的大模型 API Key",
  "dashscope_api_key": "YOUR_API_KEY_HERE",
  
  "model": "qwen-turbo",
  
  "api_settings": {
    "timeout": 30,
    "max_retries": 2
  },
  
  "email": {
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "sender": "your_email@qq.com",
    "password": "your_email_auth_code_here"
  },

  "natapp_token": "YOUR_NATAPP_AUTH_TOKEN_HERE",
  
  "web_port": 5000,
  "web_host": "0.0.0.0"
}
