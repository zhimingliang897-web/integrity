{
  "manifest_version": 3,
  "name": "21视频下载器",
  "version": "1.1.0",
  "description": "一键下载B站、NTU课程网站视频 - 无时间限制",
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "*://*.bilibili.com/*",
    "*://*.ntu.edu.sg/*",
    "*://*.ntu.edu.tw/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.bilibili.com/*",
        "*://*.ntu.edu.sg/*",
        "*://*.ntu.edu.tw/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
