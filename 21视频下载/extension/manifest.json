{
  "manifest_version": 3,
  "name": "视频下载器",
  "version": "3.0.0",
  "description": "自动检测页面视频，一键下载",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "webRequest",
    "storage",
    "downloads",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_badge_text": ""
  },
  "background": {
    "service_worker": "background.js"
  }
}
